{
  "name": "omnishapeagent",
  "version": "1.0.6",
  "description": "Local AI agent with chat, tool use, persistent memory, and vision",
  "keywords": [
    "ai",
    "agent",
    "autonomous",
    "llm",
    "ollama",
    "openrouter",
    "vllm",
    "computer-use"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "omnishapeagent": "bin/omnishapeagent.js",
    "oshape": "bin/omnishapeagent.js",
    "shapagent": "bin/omnishapeagent.js"
  },
  "files": [
    "README.md",
    "TAILSCALE.md",
    ".next/BUILD_ID",
    ".next/*.json",
    ".next/server",
    ".next/static",
    "bin",
    "bots",
    "data/.gitkeep",
    "orchestrator",
    "public",
    "scripts",
    "skills",
    "src",
    "eslint.config.mjs",
    "next-env.d.ts",
    "next.config.ts",
    "postcss.config.mjs",
    "tsconfig.json"
  ],
  "scripts": {
    "cli": "node bin/omnishapeagent.js",
    "serve": "node bin/omnishapeagent.js serve",
    "dev": "next dev --webpack -H 0.0.0.0",
    "dev:turbo": "next dev -H 0.0.0.0",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint",
    "postinstall": "node scripts/install-warning.js",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@distube/ytdl-core": "^4.16.12",
    "@types/three": "^0.183.1",
    "cheerio": "^1.2.0",
    "discord.js": "^14.26.0",
    "ffmpeg-static": "^5.3.0",
    "next": "16.2.3",
    "node-notifier": "^10.0.1",
    "nodemailer": "^8.0.5",
    "opusscript": "^0.0.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-notifier": "^8.0.5",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
